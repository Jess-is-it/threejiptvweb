# Copy this file to `.env.local` for local development.
# For production (systemd), prefer `/etc/3j-tv/3j-tv.env`.
#
# Generate a 32-byte ADMIN_DATA_KEY:
#   openssl rand -base64 32

# Required: encrypt admin-stored secrets (SSH / NAS / XUI / qBittorrent creds)
ADMIN_DATA_KEY=

# Required: systemd timer calls the scheduler tick endpoint
SCHEDULER_TOKEN=

# TMDb (metadata normalization during processing)
TMDB_API_KEY=

# Optional: allow self-signed HTTPS upstreams (only recommended for private IP hosts)
ALLOW_INSECURE_UPSTREAM_TLS=false

# Optional: public-side server selection
LOAD_BALANCING_ENABLED=true
PINNED_SERVER=

# Optional: Xuione base server list (comma-separated)
XUIONE_URLS=https://tv1.example.com,https://tv2.example.com

# Optional: mailer creds (admin forgot-password flow)
MAIL_FROM=
MAIL_USER=
MAIL_PASS=

